pipeline{
    agent any
    stages{
        stage("build"){
            steps{
                echo " This is building stage :)"
            
            }
        }
        stage("test"){
            steps{
                echo " This is testing stage :)"
            }
        }
        stage("deploy"){
            steps{
                echo " This is deploying stage :)"
            }
        }
        stage(" project completed :)"){
            steps{
                echo " Now the project was successfully completed"
            }
        }
    }
}
